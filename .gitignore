# ─── Monorepo root .gitignore ─────────────────────────────────────────────────
# Per-package ignores (node_modules, dist, .env, etc.) live in
# backend/.gitignore and frontend/.gitignore.
# This file covers root-level and cross-cutting concerns.

# Safety net: never commit node_modules or build artefacts from any package
node_modules/
dist/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs at the root
*.log
npm-debug.log*
