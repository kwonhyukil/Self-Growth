# ─────────────────────────────────────────────────────────────────────────────
# Self Growth Log — Docker Compose root environment variables
#
# Copy this file to .env in the project root.
# This file is read by docker compose for variable substitution.
#
# Backend runtime variables live in backend/.env.example
# and should be copied to backend/.env separately.
# ─────────────────────────────────────────────────────────────────────────────

# MySQL root password used by docker compose to initialize the DB container
# and to assemble the backend DATABASE_URL.
DB_ROOT_PASSWORD=rootpassword

# MySQL database name created on first container startup.
DB_NAME=self_growth_log
