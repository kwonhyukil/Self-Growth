# ─────────────────────────────────────────────────────────────────────────────
# Self Growth Log — Backend runtime environment variables
#
# Copy this file to backend/.env and fill in real values.
# The docker compose root .env is separate and only used for compose variables
# such as DB_ROOT_PASSWORD / DB_NAME.
# ─────────────────────────────────────────────────────────────────────────────

# Docker compose assembles this automatically for containers, but keeping the
# value here makes local backend execution (`npm run dev --workspace ...`) work.
DATABASE_URL=mysql://root:rootpassword@127.0.0.1:3306/self_growth_log?charset=utf8mb4

# JWT signing secret
JWT_SECRET=change_me_in_production

# JWT expiry in seconds
JWT_EXPIRES_IN=3600

# Backend HTTP port
PORT=4000

# GPT model for ja-check / verbalization
GPT_MODEL=gpt-4o-mini

# OpenAI API key consumed by backend/src/shared/infra/gpt.impl.ts
GPT_API_KEY=sk-...
