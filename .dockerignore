# ── version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── node_modules (re-installed inside the container) ──────────────────────────
node_modules
backend/node_modules
frontend/node_modules
packages/*/node_modules

# ── compiled output (rebuilt inside the container) ────────────────────────────
backend/dist
frontend/dist

# ── test artifacts ─────────────────────────────────────────────────────────────
backend/coverage
frontend/coverage

# ── environment / secrets (never bake into image) ─────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
backend/.env.test

# ── Claude / editor metadata ──────────────────────────────────────────────────
.claude
.omx
.vscode
.idea
*.code-workspace

# ── logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
